# Backend API URL — leave empty for local development (Vite proxy handles it)
# Set this in production to your Render backend URL (no trailing slash, no /api)
# Example: VITE_API_URL=https://geoconnect-api.onrender.com
VITE_API_URL=

# Google Maps (optional)
VITE_GOOGLE_MAPS_KEY=

# Mapbox (optional)
VITE_MAPBOX_TOKEN=
