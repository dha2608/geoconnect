══════════════════════════════════════════════════════════
  UI DESIGN SYSTEM — DARK GLASS MAP THEME
══════════════════════════════════════════════════════════

Philosophy:
• The MAP is the canvas — all UI floats above it as glass panels
• Dark theme by default (maps look best on dark)
• Electric blue + teal accent palette (map/geo context)
• Every panel: glassmorphism with backdrop-filter blur
• ZERO hardcoded colors — CSS variables everywhere
• Framer Motion on EVERY panel, modal, sheet, and list item

─── CSS Variables (define in index.css) ─────────────────

:root {
  /* Backgrounds */
  --bg-base: #080b12;
  --bg-elevated: #0d1117;
  --bg-panel: #0f1520;
  --bg-subtle: #131a24;
  --bg-overlay: rgba(8, 11, 18, 0.85);

  /* Accent — electric blue + teal */
  --accent-primary: #3b82f6;
  --accent-secondary: #06b6d4;
  --accent-success: #10b981;
  --accent-warning: #f59e0b;
  --accent-danger: #ef4444;
  --accent-glow: rgba(59, 130, 246, 0.30);
  --accent-glow-teal: rgba(6, 182, 212, 0.20);

  /* Text */
  --text-primary: #f1f5f9;
  --text-secondary: #94a3b8;
  --text-muted: #475569;
  --text-inverse: #0f172a;

  /* Glass */
  --glass-bg: rgba(15, 21, 32, 0.72);
  --glass-border: rgba(59, 130, 246, 0.12);
  --glass-hover: rgba(59, 130, 246, 0.07);
  --glass-active: rgba(59, 130, 246, 0.14);
  --glass-blur: blur(20px) saturate(180%);

  /* Gradients */
  --gradient-primary: linear-gradient(135deg, #3b82f6, #06b6d4);
  --gradient-secondary: linear-gradient(135deg, #06b6d4, #10b981);
  --gradient-danger: linear-gradient(135deg, #ef4444, #f97316);
  --gradient-mesh:
    radial-gradient(ellipse 70% 70% at 15% 25%,
      rgba(59,130,246,0.10) 0%, transparent 65%),
    radial-gradient(ellipse 50% 50% at 85% 80%,
      rgba(6,182,212,0.08) 0%, transparent 65%),
    radial-gradient(ellipse 40% 40% at 55% 5%,
      rgba(99,102,241,0.07) 0%, transparent 55%);

  /* Shadows */
  --shadow-sm:   0 2px 8px rgba(0,0,0,0.4);
  --shadow-md:   0 8px 32px rgba(0,0,0,0.5), 0 1px 0 rgba(255,255,255,0.04) inset;
  --shadow-lg:   0 16px 48px rgba(0,0,0,0.6), 0 1px 0 rgba(255,255,255,0.05) inset;
  --shadow-glow: 0 0 40px var(--accent-glow);
  --shadow-glow-sm: 0 0 20px var(--accent-glow);

  /* Spacing (always use these — never raw px) */
  --s-1: 4px;   --s-2: 8px;   --s-3: 12px;  --s-4: 16px;
  --s-5: 20px;  --s-6: 24px;  --s-8: 32px;  --s-10: 40px;
  --s-12: 48px; --s-16: 64px; --s-20: 80px; --s-24: 96px;

  /* Border radius */
  --r-sm:   8px;
  --r-md:   14px;
  --r-lg:   20px;
  --r-xl:   28px;
  --r-full: 9999px;

  /* Animation easing */
  --ease-out-expo:  cubic-bezier(0.16, 1, 0.3, 1);
  --ease-spring:    cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-smooth:    cubic-bezier(0.76, 0, 0.24, 1);
  --ease-in-expo:   cubic-bezier(0.7, 0, 0.84, 0);

  /* Duration */
  --d-instant: 80ms;
  --d-fast:    150ms;
  --d-normal:  300ms;
  --d-slow:    500ms;
  --d-enter:   700ms;
}

─── Glass Card (apply to ALL floating panels) ───────────

.glass {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1px solid var(--glass-border);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-md);
}
.glass:hover {
  border-color: rgba(59, 130, 246, 0.22);
  box-shadow: var(--shadow-md), var(--shadow-glow-sm);
}

─── Aurora Background (fixed, behind map controls) ─────

.aurora {
  position: fixed; inset: 0; z-index: 0;
  background: var(--bg-base);
  pointer-events: none;
}
.aurora::before {
  content: '';
  position: absolute; inset: 0;
  background: var(--gradient-mesh);
  animation: auroraShift 18s ease infinite alternate;
}
@keyframes auroraShift {
  0%   { opacity: 0.5; transform: scale(1) rotate(0deg); }
  50%  { opacity: 0.9; transform: scale(1.04) rotate(0.8deg); }
  100% { opacity: 0.6; transform: scale(0.97) rotate(-0.8deg); }
}

─── User Location Marker ────────────────────────────────

.user-dot {
  width: 14px; height: 14px;
  background: var(--accent-primary);
  border: 2.5px solid white;
  border-radius: 50%;
  box-shadow: 0 0 0 0 var(--accent-glow);
  animation: userPulse 2.2s ease-out infinite;
}
@keyframes userPulse {
  0%   { box-shadow: 0 0 0 0 rgba(59,130,246,0.7); }
  65%  { box-shadow: 0 0 0 18px rgba(59,130,246,0); }
  100% { box-shadow: 0 0 0 0 rgba(59,130,246,0); }
}

─── Layout: Map as Base, UI Floats Above ────────────────

/* Map: fills entire viewport */
.map-container { position: fixed; inset: 0; z-index: 0; }

/* UI overlay — pointer-events none so clicks pass to map */
.ui-overlay {
  position: fixed; inset: 0; z-index: 10;
  pointer-events: none;
}
/* Re-enable on actual interactive panels */
.ui-overlay > * { pointer-events: auto; }

/* Panel positions */
.panel-top-center    { top: 16px; left: 50%; transform: translateX(-50%); }
.panel-top-left      { top: 16px; left: 16px; }
.panel-top-right     { top: 16px; right: 16px; }
.panel-bottom-right  { bottom: 24px; right: 16px; }
.panel-bottom-left   { bottom: 24px; left: 16px; }
.panel-left          { top: 0; left: 0; height: 100%; width: 360px; }
.panel-bottom-sheet  { bottom: 0; left: 0; right: 0; /* mobile */ }

