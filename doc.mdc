<Button>
  variants: primary (gradient fill + glow on hover)
            ghost (glass bg, border)
            icon (square, glass)
            danger (red gradient)
  sizes:    sm | md | lg
  states:   loading (spinner inside) | disabled

<Input>
  floating label animation (label moves up on focus/fill)
  focus: blue glow ring (box-shadow)
  error: red border + shake animation + error message below
  variants: default | search (with magnifier icon)

<Modal>
  glass backdrop (blur + dark overlay)
  spring scale-in animation (Framer Motion)
  close on backdrop click + Escape key
  trap focus for accessibility

<BottomSheet> (mobile)
  drag handle at top
  spring animation from bottom
  snap to 40% and 85% screen height
  close on swipe-down past threshold

<Toast>
  slide in from top-right
  variants: success (green) | error (red) | info (blue) | warning (yellow)
  auto-dismiss after 4s with animated progress bar
  manual dismiss button
  stack multiple toasts

<Avatar>
  sizes: xs(24) sm(32) md(40) lg(56) xl(80)
  online indicator: green dot bottom-right
  live-sharing indicator: pulsing blue dot
  fallback: initials on gradient background

<Badge>
  pill shaped (border-radius: var(--r-full))
  color variants matching categories

<StarRating>
  interactive (click to rate) or display-only
  half-star support
  animated fill on hover

<CoordinateDisplay>
  monospace font
  shows: decimal degrees | DMS format
  click-to-copy with checkmark confirmation animation

